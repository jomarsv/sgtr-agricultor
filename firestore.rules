rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /*
      Estrutura assumida pelos apps:
      - usuarios/{uid}: { perfil, ativo, nome, emailInterno, macroRegiaoId?, tecnicoId?, beneficiarioId?, ... }
      - beneficiarios/{id}: { macroRegiaoId, statusCadastro, tecnico, ... }
      - diagnosticos/{beneficiarioId}
      - problemas_agricultor/{id}: { beneficiarioId, uidCriador, ... }
      - solicitacoes_visita/{id}: { beneficiarioId, uidCriador, ... }
      - visitas_tecnicas/{id}: { tecnico, beneficiario, ... }

      Para modo estrito, as queries dos apps precisam usar filtros compatíveis.
      Exemplo:
      - tecnico: where('macroRegiaoId', '==', myMacro())
      - agricultor: where('beneficiarioId', '==', myBeneficiarioId())
    */

    function signedIn() {
      return request.auth != null;
    }

    function myUserPath() {
      return /databases/$(database)/documents/usuarios/$(request.auth.uid);
    }

    function myUserExists() {
      return signedIn() && exists(myUserPath());
    }

    function myUser() {
      return get(myUserPath()).data;
    }

    function myProfile() {
      return myUserExists() ? myUser().perfil : null;
    }

    function myActive() {
      return myUserExists() && myUser().ativo == true;
    }

    function myMacro() {
      return myUserExists() ? myUser().macroRegiaoId : null;
    }

    function myTecnicoId() {
      return myUserExists() ? myUser().tecnicoId : null;
    }

    function myBeneficiarioId() {
      return myUserExists() ? myUser().beneficiarioId : null;
    }

    function isGestao() {
      return myActive() && myProfile() == 'gestao_geral';
    }

    function isSupervisor() {
      return myActive() && myProfile() == 'supervisor';
    }

    function isAdministrativo() {
      return myActive() && myProfile() == 'administrativo';
    }

    function isTecnico() {
      return myActive() && myProfile() == 'tecnico';
    }

    function isAgricultor() {
      return myActive() && myProfile() == 'agricultor';
    }

    function isEquipeInterna() {
      return isGestao() || isSupervisor() || isAdministrativo() || isTecnico();
    }

    function canManageUserStatus(target) {
      return isGestao()
        || (isSupervisor() && target.perfil in ['administrativo', 'tecnico', 'agricultor']);
    }

    function canManageTecnicoMacro(target) {
      return (isGestao() || isSupervisor()) && target.perfil == 'tecnico';
    }

    function selfUserUpdateAllowed(userId) {
      return request.auth.uid == userId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'nome',
          'emailInterno',
          'telefone',
          'cpf',
          'cpfMasked',
          'cargo',
          'instituicao',
          'lgpdConsentimentoAppsMesmoControlador',
          'lgpdConsentimentoAppsMesmoControladorEm',
          'lgpdConsentimentoAppsMesmoControladorVersao',
          'ultimoLoginEm'
        ])
        && request.resource.data.perfil == resource.data.perfil
        && request.resource.data.ativo == resource.data.ativo
        && request.resource.data.macroRegiaoId == resource.data.macroRegiaoId
        && request.resource.data.tecnicoId == resource.data.tecnicoId
        && request.resource.data.beneficiarioId == resource.data.beneficiarioId;
    }

    function managedUserUpdateAllowed(target) {
      return (
          canManageUserStatus(target)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'ativo',
            'ultimoLoginEm'
          ])
        )
        || (
          canManageTecnicoMacro(target)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'macroRegiaoId',
            'ultimoLoginEm'
          ])
        )
        || (
          canManageTecnicoMacro(target)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'ativo',
            'macroRegiaoId',
            'ultimoLoginEm'
          ])
        );
    }

    function managedUserCoreFieldsPreserved() {
      return request.resource.data.perfil == resource.data.perfil
        && request.resource.data.nome == resource.data.nome
        && request.resource.data.emailInterno == resource.data.emailInterno
        && request.resource.data.cpf == resource.data.cpf
        && request.resource.data.cpfMasked == resource.data.cpfMasked
        && request.resource.data.tecnicoId == resource.data.tecnicoId
        && request.resource.data.beneficiarioId == resource.data.beneficiarioId
        && request.resource.data.telefone == resource.data.telefone
        && request.resource.data.cargo == resource.data.cargo
        && request.resource.data.instituicao == resource.data.instituicao
        && request.resource.data.lgpdConsentimentoAppsMesmoControlador == resource.data.lgpdConsentimentoAppsMesmoControlador
        && request.resource.data.lgpdConsentimentoAppsMesmoControladorEm == resource.data.lgpdConsentimentoAppsMesmoControladorEm
        && request.resource.data.lgpdConsentimentoAppsMesmoControladorVersao == resource.data.lgpdConsentimentoAppsMesmoControladorVersao;
    }

    function tecnicoAllowedCadastroStatus(status) {
      return status in ['rascunho', 'pendente_validacao', 'aguardando_correcao'];
    }

    function administrativoAllowedCadastroStatus(status) {
      return status in ['pendente_validacao', 'aprovado', 'rejeitado', 'aguardando_correcao', 'inativo'];
    }

    function validClientTimestamp(value) {
      return value == request.time;
    }

    function isLeapYear(year) {
      return year % 400 == 0 || (year % 4 == 0 && !(year % 100 == 0));
    }

    function daysInMonth(year, month) {
      return month == 1 ? 31
        : month == 2 ? (isLeapYear(year) ? 29 : 28)
        : month == 3 ? 31
        : month == 4 ? 30
        : month == 5 ? 31
        : month == 6 ? 30
        : month == 7 ? 31
        : month == 8 ? 31
        : month == 9 ? 30
        : month == 10 ? 31
        : month == 11 ? 30
        : month == 12 ? 31
        : 0;
    }

    function validVisitDateParts(year, month, day) {
      return month >= 1
        && month <= 12
        && day >= 1
        && day <= daysInMonth(year, month);
    }

    function dayOfYearFromParts(year, month, day) {
      return day
        + (month > 1 ? 31 : 0)
        + (month > 2 ? (isLeapYear(year) ? 29 : 28) : 0)
        + (month > 3 ? 31 : 0)
        + (month > 4 ? 30 : 0)
        + (month > 5 ? 31 : 0)
        + (month > 6 ? 30 : 0)
        + (month > 7 ? 31 : 0)
        + (month > 8 ? 31 : 0)
        + (month > 9 ? 30 : 0)
        + (month > 10 ? 31 : 0)
        + (month > 11 ? 30 : 0);
    }

    function currentBrazilYear() {
      return request.time.hours() >= 3
        ? request.time.year()
        : (request.time.dayOfYear() > 1 ? request.time.year() : request.time.year() - 1);
    }

    function currentBrazilDayOfYear() {
      return request.time.hours() >= 3
        ? request.time.dayOfYear()
        : (
          request.time.dayOfYear() > 1
            ? request.time.dayOfYear() - 1
            : (isLeapYear(request.time.year() - 1) ? 366 : 365)
        );
    }

    function visitDateIsTodayOrFutureInBrazil() {
      let year = request.resource.data.dataPreferidaAno;
      let month = request.resource.data.dataPreferidaMes;
      let day = request.resource.data.dataPreferidaDia;
      let visitDayOfYear = dayOfYearFromParts(year, month, day);
      let brazilYear = currentBrazilYear();
      let brazilDayOfYear = currentBrazilDayOfYear();
      return validVisitDateParts(year, month, day)
        && (
          year > brazilYear
          || (year == brazilYear && visitDayOfYear >= brazilDayOfYear)
        );
    }

    function validProblemaAgricultorCreate() {
      return request.resource.data.uidCriador == request.auth.uid
        && request.resource.data.beneficiarioId == myBeneficiarioId()
        && request.resource.data.macroRegiaoId == myMacro()
        && request.resource.data.status == 'Novo'
        && request.resource.data.keys().hasOnly([
          'beneficiarioId',
          'beneficiarioNome',
          'uidCriador',
          'macroRegiaoId',
          'titulo',
          'categoria',
          'descricao',
          'prioridade',
          'localizacao',
          'data',
          'status',
          'imagem',
          'nomeImagem',
          'video',
          'nomeVideo',
          'createdAt'
        ])
        && validClientTimestamp(request.resource.data.createdAt);
    }

    function validSolicitacaoVisitaCreate() {
      return request.resource.data.uidCriador == request.auth.uid
        && request.resource.data.beneficiarioId == myBeneficiarioId()
        && request.resource.data.macroRegiaoId == myMacro()
        && request.resource.data.status == 'Solicitada'
        && request.resource.data.keys().hasOnly([
          'beneficiarioId',
          'beneficiarioNome',
          'uidCriador',
          'macroRegiaoId',
          'motivo',
          'dataPreferida',
          'dataPreferidaAno',
          'dataPreferidaMes',
          'dataPreferidaDia',
          'turno',
          'observacoes',
          'status',
          'dataSolicitacao',
          'createdAt'
        ])
        && visitDateIsTodayOrFutureInBrazil()
        && validClientTimestamp(request.resource.data.createdAt);
    }

    function validSolicitacaoWhatsappCreate() {
      return request.resource.data.uidCriador == request.auth.uid
        && request.resource.data.beneficiarioId == myBeneficiarioId()
        && request.resource.data.macroRegiaoId == myMacro()
        && request.resource.data.status == 'Solicitada'
        && request.resource.data.keys().hasOnly([
          'beneficiarioId',
          'beneficiarioNome',
          'uidCriador',
          'macroRegiaoId',
          'motivo',
          'observacoes',
          'telefoneContato',
          'status',
          'dataSolicitacao',
          'createdAt'
        ])
        && validClientTimestamp(request.resource.data.createdAt);
    }

    function validAccessLogCreate() {
      return request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'uid',
          'nome',
          'perfil',
          'macroRegiaoId',
          'tecnicoId',
          'beneficiarioId',
          'appOrigem',
          'evento',
          'timestamp'
        ])
        && request.resource.data.perfil == myProfile()
        && request.resource.data.macroRegiaoId == myMacro()
        && request.resource.data.beneficiarioId == myBeneficiarioId()
        && validClientTimestamp(request.resource.data.timestamp);
    }

    function canReadBeneficiario(beneficiarioId, data) {
      return isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (isTecnico() && data.macroRegiaoId == myMacro())
        || (isAgricultor() && beneficiarioId == myBeneficiarioId());
    }

    function canReadVisitaTecnica(data) {
      return isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (
          isTecnico()
          && data.tecnicoId == myTecnicoId()
        );
    }

    function tecnicoOwnVisitaWrite() {
      return request.resource.data.tecnicoId == myTecnicoId()
        && request.resource.data.macroRegiaoId == myMacro();
    }

    function canReadDiagnostico(data, beneficiarioId) {
      return isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (
          isTecnico()
          && (
            data.macroRegiaoId == myMacro()
            || data.tecnicoId == myTecnicoId()
          )
        )
        || (
          isAgricultor()
          && beneficiarioId == myBeneficiarioId()
        );
    }

    function tecnicoOwnDiagnosticoWrite(data) {
      return data.macroRegiaoId == myMacro()
        && data.tecnicoId == myTecnicoId();
    }

    match /usuarios/{userId} {
      // O próprio agricultor precisa ler seu documento logo após autenticar,
      // antes de o app concluir as validações de perfil e vínculo.
      allow get: if signedIn() && request.auth.uid == userId;

      allow list: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
      );

      allow create: if false;

      allow update: if myActive()
        && (
          selfUserUpdateAllowed(userId)
          || (managedUserUpdateAllowed(resource.data) && managedUserCoreFieldsPreserved())
        );

      allow delete: if false;
    }

    match /beneficiarios/{beneficiarioId} {
      allow read: if myActive() && canReadBeneficiario(beneficiarioId, resource.data);

      allow create: if myActive() && (
        isGestao()
        || isSupervisor()
        || (
          isAdministrativo()
          && request.resource.data.statusCadastro in ['aprovado', 'pendente_validacao', 'rejeitado', 'aguardando_correcao', 'inativo']
        )
        || (
          isTecnico()
          && request.resource.data.macroRegiaoId == myMacro()
          && tecnicoAllowedCadastroStatus(request.resource.data.statusCadastro)
        )
      );

      allow update: if myActive() && (
        isGestao()
        || isSupervisor()
        || (
          isAdministrativo()
          && administrativoAllowedCadastroStatus(request.resource.data.statusCadastro)
        )
        || (
          isTecnico()
          && resource.data.macroRegiaoId == myMacro()
          && request.resource.data.macroRegiaoId == resource.data.macroRegiaoId
          && tecnicoAllowedCadastroStatus(request.resource.data.statusCadastro)
        )
      );

      allow delete: if isGestao() || isSupervisor();
    }

    match /diagnosticos/{beneficiarioId} {
      allow read: if myActive() && canReadDiagnostico(resource.data, beneficiarioId);

      allow create: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (
          isTecnico()
          && tecnicoOwnDiagnosticoWrite(request.resource.data)
        )
      );

      allow update: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (
          isTecnico()
          && tecnicoOwnDiagnosticoWrite(request.resource.data)
          && (
            resource.data.tecnicoId == myTecnicoId()
            || resource.data.macroRegiaoId == myMacro()
          )
        )
      );

      allow delete: if isGestao() || isSupervisor();
    }

    match /visitas_tecnicas/{visitaId} {
      allow read: if myActive() && (
        canReadVisitaTecnica(resource.data)
        || (
          isAgricultor()
          && resource.data.beneficiarioId == myBeneficiarioId()
        )
      );

      allow create: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (isTecnico() && tecnicoOwnVisitaWrite())
      );

      allow update: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (
          isTecnico()
          && resource.data.tecnicoId == myTecnicoId()
          && tecnicoOwnVisitaWrite()
        )
      );

      allow delete: if isGestao() || isSupervisor();
    }

    match /problemas_agricultor/{docId} {
      allow read: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (
          isTecnico()
          && resource.data.macroRegiaoId == myMacro()
        )
        || (
          isAgricultor()
          && resource.data.beneficiarioId == myBeneficiarioId()
        )
      );

      allow create: if myActive()
        && isAgricultor()
        && validProblemaAgricultorCreate();

      allow update: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (
          isTecnico()
          && resource.data.macroRegiaoId == myMacro()
        )
      );

      allow delete: if false;
    }

    match /solicitacoes_visita/{docId} {
      allow read: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (
          isTecnico()
          && resource.data.macroRegiaoId == myMacro()
        )
        || (
          isAgricultor()
          && resource.data.beneficiarioId == myBeneficiarioId()
        )
      );

      allow create: if myActive()
        && isAgricultor()
        && validSolicitacaoVisitaCreate();

      allow update: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (
          isTecnico()
          && resource.data.macroRegiaoId == myMacro()
        )
      );

      allow delete: if false;
    }

    match /solicitacoes_whatsapp/{docId} {
      allow read: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (
          isTecnico()
          && resource.data.macroRegiaoId == myMacro()
        )
        || (
          isAgricultor()
          && resource.data.beneficiarioId == myBeneficiarioId()
        )
      );

      allow create: if myActive()
        && isAgricultor()
        && validSolicitacaoWhatsappCreate();

      allow update: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (
          isTecnico()
          && resource.data.macroRegiaoId == myMacro()
        )
      );

      allow delete: if false;
    }

    match /consultas_ia_agro/{docId} {
      allow read: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (isTecnico() && resource.data.macroRegiaoId == myMacro())
      );

      allow create: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (
          isTecnico()
          && request.resource.data.macroRegiaoId == myMacro()
          && request.resource.data.tecnicoId == myTecnicoId()
        )
      );

      allow update: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (
          isTecnico()
          && resource.data.macroRegiaoId == myMacro()
          && resource.data.tecnicoId == myTecnicoId()
          && request.resource.data.macroRegiaoId == resource.data.macroRegiaoId
          && request.resource.data.tecnicoId == resource.data.tecnicoId
        )
      );

      allow delete: if isGestao() || isSupervisor();
    }

    match /analises_imagem_ia/{docId} {
      allow read: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (isTecnico() && resource.data.macroRegiaoId == myMacro())
      );

      allow create: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (
          isTecnico()
          && request.resource.data.macroRegiaoId == myMacro()
          && request.resource.data.tecnicoId == myTecnicoId()
        )
      );

      allow update: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (
          isTecnico()
          && resource.data.macroRegiaoId == myMacro()
          && resource.data.tecnicoId == myTecnicoId()
          && request.resource.data.macroRegiaoId == resource.data.macroRegiaoId
          && request.resource.data.tecnicoId == resource.data.tecnicoId
        )
      );

      allow delete: if isGestao() || isSupervisor();
    }

    match /historico_orientacoes_ia/{docId} {
      allow read: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (isTecnico() && resource.data.macroRegiaoId == myMacro())
      );

      allow create: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (
          isTecnico()
          && request.resource.data.macroRegiaoId == myMacro()
          && request.resource.data.tecnicoId == myTecnicoId()
        )
      );

      allow update: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (
          isTecnico()
          && resource.data.macroRegiaoId == myMacro()
          && resource.data.tecnicoId == myTecnicoId()
          && request.resource.data.macroRegiaoId == resource.data.macroRegiaoId
          && request.resource.data.tecnicoId == resource.data.tecnicoId
        )
      );

      allow delete: if isGestao() || isSupervisor();
    }

    match /respostas_aprovadas_ia/{docId} {
      allow read: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (isTecnico() && resource.data.macroRegiaoId == myMacro())
      );

      allow create: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (
          isTecnico()
          && request.resource.data.macroRegiaoId == myMacro()
          && request.resource.data.criadoPorUid == request.auth.uid
        )
      );

      allow update: if myActive() && (
        isGestao()
        || isSupervisor()
        || isAdministrativo()
        || (
          isTecnico()
          && resource.data.macroRegiaoId == myMacro()
          && resource.data.criadoPorUid == request.auth.uid
          && request.resource.data.macroRegiaoId == resource.data.macroRegiaoId
          && request.resource.data.criadoPorUid == resource.data.criadoPorUid
        )
      );

      allow delete: if isGestao() || isSupervisor();
    }

    match /access_logs/{logId} {
      allow create: if myActive() && validAccessLogCreate();
      allow read: if isGestao() || isSupervisor();
      allow update, delete: if false;
    }

    match /arquivos_area/{docId} {
      allow read: if isGestao() || isSupervisor() || isAdministrativo();
      allow create, update: if isGestao() || isSupervisor() || isAdministrativo();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
